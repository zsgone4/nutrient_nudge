// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MicroStatus {
  MEASURED // real composition data (CoFID / USDA), or rich enough on its own
  PROXY    // micronutrients borrowed from a similar MEASURED food
  NONE     // no data and no safe proxy → hidden / blocked
}

model Signup {
  id                 String         @id @default(cuid())
  email              String         @unique
  name               String
  age                Int
  gender             String
  trainingGoal       String?
  goals              String
  agreedToPolicy     Boolean
  emailVerified      Boolean        @default(false)
  verificationToken  String?        @unique
  verifiedAt         DateTime?
  createdAt          DateTime       @default(now())
  userProfile        UserProfile?
  foodLogEntries     FoodLogEntry[]
  nutrientScores     NutrientScore[]
  savedMeals         SavedMeal[]
}

model UserProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             Signup   @relation(fields: [userId], references: [id], onDelete: Cascade)
  heightCm         Int
  weightKg         Float
  sex              String   // 'male' | 'female'
  activityLevel    String   // 'sedentary' | 'light' | 'moderate' | 'active' | 'very_active'
  goal             String   // 'aggressive_cut' | 'conservative_cut' | 'maintain' | 'conservative_bulk' | 'aggressive_bulk'
  isSetup          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Food {
  id               String         @id @default(cuid())
  barcode          String?        @unique
  name             String
  brand            String?
  servingSize      Float
  servingUnit      String
  category         String         // 'fruits' | 'vegetables' | 'grains' | 'protein' | 'dairy' | 'fats' | 'snacks' | 'beverages' | 'prepared'
  image            String?

  // Where this food came from (used by the importer to dedupe and re-run safely)
  source           String?        // 'usda' | 'cofid' | 'openfoodfacts' | 'user'
  sourceId         String?        // e.g. USDA fdcId or barcode

  // Macronutrients — REQUIRED (almost always present)
  calories         Float
  protein          Float          // grams
  carbohydrates    Float          // grams
  fat              Float          // grams

  // Often missing on packaged foods — OPTIONAL (null = unknown, not zero)
  fiber            Float?         // grams
  sugar            Float?         // grams

  // Micronutrients — OPTIONAL (null = unknown, not zero)
  vitaminA         Float?         // mcg RAE
  vitaminB1        Float?         // mg
  vitaminB2        Float?         // mg
  vitaminB3        Float?         // mg
  vitaminB5        Float?         // mg
  vitaminB6        Float?         // mg
  vitaminB7        Float?         // mcg
  vitaminB9        Float?         // mcg
  vitaminB12       Float?         // mcg
  vitaminC         Float?         // mg
  vitaminD         Float?         // mcg
  vitaminE         Float?         // mg
  vitaminK         Float?         // mcg

  calcium          Float?         // mg
  iron             Float?         // mg
  magnesium        Float?         // mg
  phosphorus       Float?         // mg
  potassium        Float?         // mg
  sodium           Float?         // mg
  zinc             Float?         // mg
  copper           Float?         // mg
  manganese        Float?         // mg
  selenium         Float?         // mcg
  chromium         Float?         // mcg
  iodine           Float?         // mcg

  // --- Micronutrient profile resolution -------------------------------
  // Every usable food ends up MEASURED or PROXY. NONE = no data and no safe
  // match → hidden from search and blocked from logging.
  // Defaults to MEASURED so a deploy never hides the DB before the backfill runs.
  microStatus      MicroStatus    @default(MEASURED)
  microProxyFoodId String?        // donor food this profile was borrowed from
  microProxyFood   Food?          @relation("MicroProxy", fields: [microProxyFoodId], references: [id])
  proxiedFoods     Food[]         @relation("MicroProxy")
  microMatchName   String?        // donor name, for the "Estimated from …" label
  microMatchScore  Float?         // 0..1 match confidence when PROXY

  foodLogEntries   FoodLogEntry[]
  createdAt        DateTime       @default(now())

  // Lets the seed script run more than once without creating duplicates.
  // (Postgres allows multiple NULLs here, so user-added foods won't collide.)
  @@unique([source, sourceId])
  @@index([microStatus])
  @@index([category])
}

model FoodLogEntry {
  id               String   @id @default(cuid())
  userId           String
  user             Signup   @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodId           String
  food             Food     @relation(fields: [foodId], references: [id])
  servings         Float
  mealType         String   // 'breakfast' | 'lunch' | 'dinner' | 'snacks'
  date             String   // YYYY-MM-DD format
  timestamp        BigInt
  createdAt        DateTime @default(now())
}

model NutrientScore {
  id               String   @id @default(cuid())
  userId           String
  user             Signup   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             String   // YYYY-MM-DD format
  score            Float    // 0-100 score based on micronutrient completeness
  micronutrients   String   // JSON string with detailed breakdown of micronutrient coverage
  createdAt        DateTime @default(now())

  @@unique([userId, date])
}

model SavedMeal {
  id          String          @id
  userId      String
  user        Signup          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  items       SavedMealItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
}

model SavedMealItem {
  id          String    @id @default(cuid())
  savedMealId String
  savedMeal   SavedMeal @relation(fields: [savedMealId], references: [id], onDelete: Cascade)
  foodData    String    @default("{}") // JSON snapshot of Food object
  servings    Float
}
